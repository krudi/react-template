{
    "extends": "@krudi/typescript-config/nextjs.json",
    "compilerOptions": {
        "paths": {
            "@/*": ["./src/*"],
            "@app/*": ["./src/app/*"],
            "@components/*": ["./src/components/*"],
            "@lib/*": ["./src/lib/*"],
            "@utils/*": ["./src/utils/*"],
            "@styles/*": ["./src/styles/*"],
            "@models": ["./src/types/index"],
            "@models/*": ["./src/types/*"]
        }
    },
    "include": [
        "next-env.d.ts",
        "src/**/*.ts",
        "src/**/*.tsx",
        "client.d.ts",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts"
    ],
    "exclude": ["node_modules"]
}
